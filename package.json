{
  "name": "comfy-qa",
  "version": "0.0.0",
  "description": "ComfyUI QA automation CLI",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "bin": {
    "comfy-qa": "./src/cli.ts",
    "cmqa": "./src/cli.ts"
  },
  "files": [
    "src/"
  ],
  "engines": {
    "bun": ">=1"
  },
  "scripts": {
    "start": "bun src/cli.ts",
    "dev": "bun --hot src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --compile --outfile dist/comfy-qa",
    "prepare": "git submodule update --init --remote && cd lib/demowright && bun install && bun run build",
    "postinstall": "git submodule update --init --remote && cd lib/demowright && bun install && bun run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  }
}
