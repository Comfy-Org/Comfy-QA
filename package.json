{
  "name": "comfy-qa",
  "version": "0.1.0",
  "description": "ComfyUI QA automation CLI",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "type": "module",
  "bin": {
    "comfy-qa": "./src/cli.ts"
  },
  "scripts": {
    "start": "bun src/cli.ts",
