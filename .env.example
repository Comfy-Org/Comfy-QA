# Copy to .env.local and fill in values.
#   cp .env.example .env.local

# ── TTS Narration ──────────────────────────────────────────────────────────────
# At least one is required for narrated demos.
# Gemini: https://aistudio.google.com/app/api-keys
GEMINI_API_KEY=...
# OpenAI: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=...

# ── Cloud ComfyUI (staging) ───────────────────────────────────────────────────
# Staging editor — requires an account on nightly.engcomfy.com
CLOUD_URL=https://nightly.engcomfy.com/
CLOUD_USERNAME=...
CLOUD_PASSWORD=...

# ── Comfy Registry (staging) ──────────────────────────────────────────────────
# Staging registry — requires an account on stagingregistry.comfy.org
REGISTRY_URL=https://stagingregistry.comfy.org/
REGISTRY_USERNAME=...
REGISTRY_PASSWORD=...

# ── Registry Auth (email login) ──────────────────────────────────────────────
# Used to sign in to registry.comfy.org via email/password (not OAuth)
GOOGLE_USERNAME=...
GOOGLE_PASSWORD=...

# ── Slack Bot ────────────────────────────────────────────────────────────────
# Create app at https://api.slack.com/apps (Socket Mode + Events)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
QABOT_ADMIN=U...              # Slack user ID allowed to DM the bot
QABOT_CHANNEL=qa-bot-playground  # Channel the bot responds in

# ── AI (for Slack bot) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-...
